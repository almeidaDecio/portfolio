---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
---

<header
  class="flex flex-col gap-4"
  class:list={{ "items-center text-center": align === "center", "items-start": align !== "center" }}
>
  {eyebrow && (
    <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">
      <span class="h-1 w-1 rounded-full bg-foreground" />
      {eyebrow}
    </span>
  )}
  <h2 class="text-pretty text-3xl font-semibold tracking-tight md:text-4xl">
    {title}
  </h2>
  {description && (
    <p
      class="max-w-4xl text-pretty text-base leading-relaxed text-muted-foreground md:text-lg"
      class:list={{ "mx-auto": align === "center" }}
    >
      {description}
    </p>
  )}
</header>
