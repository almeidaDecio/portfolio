---
import Layout from "../components/Layout.astro";
import PageContainer from "../components/PageContainer.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { icon } from "../components/icons";

const channels = [
  {
    label: "E-mail",
    value: "decio.almeida.1969@gmail.com",
    href: "mailto:decio.almeida.1969@gmail.com",
    copyValue: "decio.almeida.1969@gmail.com",
    iconType: "mail",
  },
  {
    label: "LinkedIn",
    value: "linkedin.com/in/décio-d-almeida",
    href: "https://www.linkedin.com/in/d%C3%A9cio-d-almeida-74186621/",
    copyValue: "https://www.linkedin.com/in/d%C3%A9cio-d-almeida-74186621/",
    iconType: "linkedin",
  },
];
---

<Layout
  pathname={Astro.url.pathname}
  title="Contato"
  description="Entre em contato com Décio D'Almeida: e-mail e LinkedIn."
>
  <PageContainer>
    <section class="max-w-2xl -mt-6">
      <SectionHeader
        title="Vamos conversar?"
        description="Aberto a oportunidades full-time, contratos e colaborações\nBaseado na cidade de Porecatu, PR"
      />

      <div class="mt-10 space-y-3">
        {channels.map((c, i) => (
          <a
            href={c.href}
            target={c.href.startsWith("http") ? "_blank" : undefined}
            rel="noreferrer"
            class="animate-fade-up group flex w-full items-center gap-4 rounded-2xl border border-border bg-card p-5 transition-all hover:border-foreground/30"
            style={`animation-delay: ${i * 0.06}s`}
          >
            <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-border bg-background">
              <span class="[&>svg]:h-4 [&>svg]:w-4" set:html={icon(c.iconType)}></span>
            </span>

            <div class="flex-1">
              <div class="text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">
                {c.label}
              </div>
              <div class="mt-0.5 text-sm font-medium">
                {c.value}
              </div>
            </div>

            <button
              type="button"
              data-copy={c.copyValue}
              data-label={c.label}
              class="copy-btn group/tooltip relative flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
            >
              <span class="copy-icon [&>svg]:h-4 [&>svg]:w-4" set:html={icon("copy")}></span>
              <span class="check-icon hidden [&>svg]:h-4 [&>svg]:w-4 text-emerald-500" set:html={icon("check")}></span>
              <span class="absolute -top-8 left-1/2 -translate-x-1/2 rounded-md border border-border bg-popover px-2 py-1 text-xs text-popover-foreground opacity-0 shadow-sm transition-opacity group-hover/tooltip:opacity-100 pointer-events-none whitespace-nowrap">
                Copiar
              </span>
            </button>
          </a>
        ))}
      </div>
    </section>
  </PageContainer>
</Layout>

<script>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const text = btn.dataset.copy;
      const label = btn.dataset.label;
      try {
        await navigator.clipboard.writeText(text);
        const copyIcon = btn.querySelector(".copy-icon");
        const checkIcon = btn.querySelector(".check-icon");
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 1500);
      } catch {}
    });
  });
</script>
